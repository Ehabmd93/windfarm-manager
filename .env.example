# Copy this file to .env and fill in values for local dev
# Railway sets these automatically in production

SECRET_KEY=change-me-to-a-long-random-string
FLASK_DEBUG=false

# Leave blank to use local SQLite (windfarm.db)
# Railway Postgres sets this automatically
DATABASE_URL=

# Leave blank to use local static/ folder
# On Railway with a volume, set to /data
DATA_DIR=
